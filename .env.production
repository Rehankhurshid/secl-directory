# Production Environment Variables
# These will need to be set in Railway dashboard

# Database Configuration (Railway will provide this)
DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
NODE_ENV=production
PORT=3000

# Firebase Configuration (Optional - for push notifications)
# FIREBASE_API_KEY=your_production_firebase_api_key
# FIREBASE_PROJECT_ID=your_production_firebase_project_id
# FIREBASE_SENDER_ID=your_production_firebase_sender_id
# FIREBASE_CLIENT_EMAIL=your_production_firebase_client_email
# FIREBASE_PRIVATE_KEY=your_production_firebase_private_key
# FIREBASE_VAPID_KEY=your_production_firebase_vapid_key

# Twilio Configuration (Optional - for SMS OTP)
# TWILIO_ACCOUNT_SID=your_production_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_production_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_production_twilio_phone_number

# 2Factor.in API (Optional - alternative SMS provider)
# TWOFACTOR_API_KEY=your_production_2factor_api_key 